# MetaTrader Environment Configuration
# Copy this to .env and fill in values
# WARNING: Change all default passwords before deploying!

# App
SECRET_KEY=change-me-use-openssl-rand-hex-32
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://metatrader:metatrader@localhost:5432/metatrader

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Binance.US (empty for public endpoints — only needed for account/trading)
BINANCE_API_KEY=
BINANCE_API_SECRET=
# BINANCE_API_BASE=https://api.binance.us
# BINANCE_WS_BASE=wss://stream.binance.us:9443/ws

# ChromaDB
# CHROMA_PERSIST_DIR=./chroma_data

# CORS
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Auth (defaults shown — uncomment to override)
# ACCESS_TOKEN_EXPIRE_MINUTES=15
# REFRESH_TOKEN_EXPIRE_DAYS=7
# ALGORITHM=HS256
# APP_NAME=MetaTrader